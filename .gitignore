frontend/.nuxt/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Docker ────────────────────────────────────────────────────────────────────
# Do NOT ignore docker-compose files — they are source
# Ignore local override files
