# ── Default: normalize all text files to LF ──────────────────────────────────
* text=auto eol=lf

# ── Explicitly text ───────────────────────────────────────────────────────────
*.py        text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.ini       text eol=lf
*.cfg       text eol=lf
*.json      text eol=lf
*.sh        text eol=lf
*.sql       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
Dockerfile  text eol=lf
Makefile    text eol=lf
.env*       text eol=lf

# ── Binary assets: do not diff or merge ───────────────────────────────────────
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       text eol=lf
*.pdf       binary
*.docx      binary
*.xlsx      binary
*.zip       binary
*.tar.gz    binary
*.whl       binary

# ── AI model weights ──────────────────────────────────────────────────────────
*.bin       binary
*.safetensors binary
*.gguf      binary
*.ggml      binary
*.pt        binary
*.pth       binary
