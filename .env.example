# Database used by local backend and docker compose
POSTGRES_USER=vaic_nextlevel
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=vaic_nextlevel_db
DATABASE_URL=postgresql+asyncpg://vaic_nextlevel:change-me-strong-password@localhost:5434/vaic_nextlevel_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Application
APP_NAME="VAIC Banking RAG API"
APP_VERSION=1.0.0
ENV=development
DEBUG=false
LOG_LEVEL=INFO

# AI services
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_SERVICE_URL=http://localhost:8001
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_CONCURRENCY=4
EMBEDDING_MAX_RETRIES=2
EMBEDDING_RETRY_DELAY=2.0
EMBEDDING_TIMEOUT=60.0
EMBEDDING_BATCH_TIMEOUT=120.0
MODEL_LOAD_STRATEGY=lazy

# LLM service, compatible with DeepSeek or OpenAI-compatible gateways
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.2
LLM_RETRY_COUNT=2
LLM_TIMEOUT=60.0
LLM_TOP_P=0.9
LLM_MAX_PROMPT_TOKENS=6000
LLM_STREAMING_ENABLED=true

# Security
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-generate-with-secrets-token-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
BCRYPT_ROUNDS=12

# CORS / trusted hosts
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost"]
ALLOWED_HOSTS=["localhost","127.0.0.1"]

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_CONTENT_TYPES=["application/pdf","application/vnd.openxmlformats-officedocument.wordprocessingml.document","application/msword","text/plain"]

# Search / retrieval
SEARCH_DEFAULT_TOP_K=10
SEARCH_MAX_TOP_K=50
SEARCH_BM25_TOP_K=20
SEARCH_BM25_THRESHOLD=0.0
SEARCH_VECTOR_TOP_K=20
SEARCH_VECTOR_THRESHOLD=0.0
SEARCH_HYBRID_ALPHA=0.7
SEARCH_HYBRID_BETA=0.3

# Knowledge intelligence
KI_EXPANSION_DEPTH=2
KI_MAX_RELATIONS=20
KI_MAX_CITATIONS=10
KI_MAX_CONTEXT_CHUNKS=15
KI_TIMELINE_ENABLED=true
KI_CITATION_ENABLED=true
KI_CONFLICT_DETECTION_ENABLED=true
KI_AUTHORITY_WEIGHT=0.2

# Ingestion
DATA_DIR=../data/raw

# Rate limiting
RATE_LIMIT_QUERY=10/minute
RATE_LIMIT_UPLOAD=5/minute

# Frontend compatibility
NEXT_PUBLIC_API_URL=http://localhost:8000
REACT_APP_API_URL=http://localhost:8000
