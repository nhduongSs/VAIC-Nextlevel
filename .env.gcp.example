# Copy thành .env trên VM rồi điền giá trị thật:  cp .env.gcp.example .env
# Dùng bởi docker-compose.gcp.yml (backend + Postgres + embedding + Caddy).

# ── Postgres (chạy trong compose, không expose ra ngoài) ─────────────────────
POSTGRES_USER=vaic_nextlevel
POSTGRES_PASSWORD=đổi-thành-mật-khẩu-mạnh
POSTGRES_DB=vaic_nextlevel_db

# ── LLM (DeepSeek / gateway tương thích OpenAI) ──────────────────────────────
# KEY, BASE_URL và MODEL phải KHỚP nhà cung cấp:
#   OpenRouter : key sk-or-v1-... | base https://openrouter.ai/api/v1 | model deepseek/deepseek-chat
#   DeepSeek   : key sk-...       | base https://api.deepseek.com      | model deepseek-chat
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-chat

# ── Bảo mật ──────────────────────────────────────────────────────────────────
# Sinh bằng: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# ── Domain & CORS ─────────────────────────────────────────────────────────────
# Domain backend, phải trỏ A record về IP tĩnh của VM (Caddy dùng để xin cert)
BACKEND_DOMAIN=api.your-domain.com
# JSON array — PHẢI có URL frontend Railway (https). Ví dụ:
ALLOWED_ORIGINS=["https://your-frontend.up.railway.app"]
# JSON array — PHẢI có domain backend, VÀ localhost/127.0.0.1 để healthcheck
# nội bộ (curl localhost trong container) không bị TrustedHostMiddleware chặn 400.
ALLOWED_HOSTS=["api.your-domain.com","localhost","127.0.0.1"]

# ── Embedding ─────────────────────────────────────────────────────────────────
# lazy = nạp model khi có request đầu (khởi động nhanh, request đầu chậm)
MODEL_LOAD_STRATEGY=lazy
