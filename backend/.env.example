# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=vaic_nextlevel
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=vaic_nextlevel_db
DATABASE_URL=postgresql+asyncpg://vaic_nextlevel:change-me-strong-password@localhost:5434/vaic_nextlevel_db

# ── AI Services ──────────────────────────────────────────────────────────────
EMBEDDING_SERVICE_URL=http://embedding-service:8001
MODEL_LOAD_STRATEGY=lazy
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-generate-with-secrets-token-hex-32

# ── Application ───────────────────────────────────────────────────────────────
ENV=development
DEBUG=false
LOG_LEVEL=INFO
